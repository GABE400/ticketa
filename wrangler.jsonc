{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ticketa",
  "pages_build_output_dir": ".open-next",
  "main": ".open-next/worker.js",
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "compatibility_date": "2026-04-16",
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
